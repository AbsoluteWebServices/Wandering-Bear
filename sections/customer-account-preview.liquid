{%- doc -%}
  QA preview / state gallery for the account dashboard. Renders `customer-dashboard` for every
  tier x subscription combo with MOCK data (preview: true) so the whole layout can be reviewed on
  one page — no login-per-state, no worker. NOT wrapped in [data-wb-account], so account.ts never
  hydrates/overwrites the mock values (the SSR guess_none already picks the right Row-1 variant).

  Assign to a page via templates/page.account-preview.json and view at /pages/<handle>.
  Internal QA only — do not link from storefront nav.
{%- enddoc -%}

<section class="w-full" style="background-color: var(--color-brand-beige);">
  <div class="account-container py-8 md:!py-12">
    <h1 class="font-kurdis-condensed font-extrabold text-espresso text-[28px] leading-none mb-2">Account dashboard — QA states</h1>
    <p class="body text-espresso mb-8">Mock data, no worker. Resize to 375 / 750 / 1024 to check responsive. Each block below is one state.</p>

    {%- assign lbl = 'mb-3 mt-10 pt-6 border-t-2 border-espresso/30 font-kurdis-semi-condensed font-bold text-[13px] uppercase text-espresso' -%}
    {%- assign items2 = 'Cold Brew On Tap (96 oz) - Mocha|Cold Brew On Tap (96 oz) - Toasted Coconut' -%}

    <div class="{{ lbl }}">1 · FREE · no subscription · $0 · progress → VIP</div>
    {%- render 'customer-dashboard', preview: true, tier: 'FREE', autoship_state: 'none', first_name: 'Sam',
        credits_formatted: '$0.00', credits_earned_formatted: '$0.00',
        next_tier_label: 'VIP', progress_percent: 0, progress_text: 'Spend $250.00 more to reach VIP status' -%}

    <div class="{{ lbl }}">2 · FREE · cancelled subscription · $5 (no expiry → Total earned)</div>
    {%- render 'customer-dashboard', preview: true, tier: 'FREE', autoship_state: 'cancelled', first_name: 'Sam',
        credits_formatted: '$5.00', credits_earned_formatted: '$5.00',
        autoship_bundle: '96oz Bundle – 2 Boxes', autoship_items: items2, autoship_more: 1,
        next_tier_label: 'VIP', progress_percent: 0, progress_text: 'Spend $250.00 more to reach VIP status' -%}

    <div class="{{ lbl }}">3 · VIP · 1 active · $4.20 + expiry · progress → ELITE</div>
    {%- render 'customer-dashboard', preview: true, tier: 'VIP', autoship_state: 'active', first_name: 'Alex',
        credits_formatted: '$4.20', credits_expiry: '01/01/2028',
        autoship_count: 1, autoship_bundle: '96oz Bundle – 2 Boxes', autoship_next_date: '2026-08-09',
        autoship_items: 'Cold Brew On Tap (96 oz) - Mocha', autoship_more: 0,
        next_tier_label: 'ELITE', progress_percent: 60, progress_text: 'Spend $250.00 more to reach ELITE status' -%}

    <div class="{{ lbl }}">4 · VIP · 2 active · $12 (no expiry) · “+1 more”</div>
    {%- render 'customer-dashboard', preview: true, tier: 'VIP', autoship_state: 'active', first_name: 'Alex',
        credits_formatted: '$12.00', credits_earned_formatted: '$20.00',
        autoship_count: 2, autoship_bundle: 'Mixed Autoship', autoship_next_date: '2026-09-01',
        autoship_items: items2, autoship_more: 1,
        next_tier_label: 'ELITE', progress_percent: 80, progress_text: 'Spend $100.00 more to reach ELITE status' -%}

    <div class="{{ lbl }}">5 · VIP · no subscription · $10 (wide credit; Redeem/Upgrade + links aligned)</div>
    {%- render 'customer-dashboard', preview: true, tier: 'VIP', autoship_state: 'none', first_name: 'Alex',
        credits_formatted: '$10.00', credits_earned_formatted: '$10.00',
        next_tier_label: 'ELITE', progress_percent: 50, progress_text: 'Spend $250.00 more to reach ELITE status' -%}

    <div class="{{ lbl }}">6 · ELITE · 1 active · $30 + expiry (no progress column / no upgrade; 6 benefits)</div>
    {%- render 'customer-dashboard', preview: true, tier: 'ELITE', autoship_state: 'active', first_name: 'Jordan',
        credits_formatted: '$30.00', credits_expiry: '06/01/2028',
        autoship_count: 1, autoship_bundle: 'Elite Autoship', autoship_next_date: '2026-10-01',
        autoship_items: items2, autoship_more: 0 -%}

    <div class="{{ lbl }}">7 · ELITE · no subscription · $0</div>
    {%- render 'customer-dashboard', preview: true, tier: 'ELITE', autoship_state: 'none', first_name: 'Jordan',
        credits_formatted: '$0.00', credits_earned_formatted: '$0.00' -%}
  </div>
</section>

{% schema %}
{
  "name": "Account QA preview",
  "settings": []
}
{% endschema %}
