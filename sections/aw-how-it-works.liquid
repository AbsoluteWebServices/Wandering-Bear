{% liquid
  assign s = section.settings

  assign subtitle = s.subtitle
  assign subtitle_color = s.subtitle_color | default: '#AF7404'

  assign title_type = s.title_type | default: 'text'
  assign title = s.title
  assign title_color = s.title_color | default: '#431A03'
  assign title_alt = s.title_alt
  assign title_image = s.title_image
  assign title_image_mobile = s.title_image_mobile

  assign badge = s.badge
  assign badge_offset_x = s.badge_offset_x | default: 0
  assign badge_offset_y = s.badge_offset_y | default: 0
  assign badge_rotate = s.badge_rotate | default: 0
%}

{% capture subtitle_styles %}
  --subtitle-size: {{ s.subtitle_font_size | default: 16 }}px;
  --subtitle-size-mobile: {{ s.subtitle_font_size_mobile | default: 14 }}px;
{% endcapture %}

{% capture title_styles %}
  --font-size: {{ s.font_size | default: 35 }}px;
  --font-size-mobile: {{ s.font_size_mobile | default: 35 }}px;
{% endcapture %}

<div
  class="aw-how-it-works relative overflow-x-clip spacing-style wb-section-bg"
  style="{% render 'section-background', settings: s, part: 'style', fallback_color: 'transparent' %} {% render 'spacing-style', settings: s %} {{ subtitle_styles }} {{ title_styles }}"
  {{ section.shopify_attributes }}
>
  {% render 'section-background', settings: s, part: 'media' %}

  {% if badge != blank %}
    <div
      class="aw-how-it-works__badge absolute hidden z-2 pointer-events-none lg:block -top-11 right-[116px]"
      style="transform: translate({{ badge_offset_x }}px, {{ badge_offset_y }}px) rotate({{ badge_rotate }}deg);"
    >
      {{ badge | image_url: width: 300 | image_tag: class: 'w-[115px] h-auto block', loading: 'lazy', alt: '' }}
    </div>
  {% endif %}

  <div class="relative z-1 w-full max-w-[595px] mx-auto px-4 smd:px-6 md:px-0">
    <div class="flex flex-col items-center text-center gap-1.5 mb-6 smd:mb-10">
      {% if subtitle != blank %}
        <p
          class="aw-how-it-works__subtitle font-gothic_condensed font-extrabold uppercase leading-none tracking-normal"
          style="color: {{ subtitle_color }}"
        >
          {{ subtitle }}
        </p>
      {% endif %}

      {% if title_type == 'image' %}
        {% if title_image != blank %}
          <div class="w-full max-w-[340px]">
            {% render 'title-image',
              image: title_image,
              image_mobile: title_image_mobile,
              alt: title_alt,
              class: 'w-full max-h-full object-contain mx-auto',
              loading: 'lazy'
            %}
          </div>
        {% endif %}
      {% elsif title_type == 'text' %}
        {% if title != blank %}
          <h2
            class="aw-how-it-works__title font-kurdis-condensed font-extrabold leading-none"
            style="color: {{ title_color }}"
          >
            {{ title | replace: '\n', '<br>' }}
          </h2>
        {% endif %}
      {% endif %}
    </div>

    {% if section.blocks.size > 0 %}
      <div class="flex flex-col gap-4 smd:gap-4.5">
        {% for block in section.blocks %}
          {% liquid
            assign action_type = block.settings.action_type | default: 'none'
            assign join_label = block.settings.join_label | default: 'JOIN FOR FREE'
            assign custom_label = block.settings.custom_button_label
            assign custom_link = block.settings.custom_button_link
            assign custom_style = block.settings.custom_button_style | default: 'secondary'
            assign link_label = block.settings.link_label
            assign link_url = block.settings.link_url
            assign show_action = false

            if action_type == 'join' and join_label != blank
              unless customer
                assign show_action = true
              endunless
            elsif action_type == 'custom_button' and custom_label != blank and custom_link != blank
              assign show_action = true
            elsif action_type == 'link' and link_label != blank and link_url != blank
              assign show_action = true
            endif
          %}

          <div
            class="aw-how-it-works__card relative flex flex-col bg-[#FEF8F3] rounded-[10px] shadow-[0_4px_4px_rgba(0,0,0,0.25)] px-4.5 pt-1.25 smd:mb-0 smd:px-6 smd:flex-row smd:items-center smd:justify-between smd:gap-6{% if show_action and action_type == 'join' or show_action and action_type == 'custom_button' %} pb-6.5 mb-5 smd:pb-4{% elsif show_action and action_type == 'link' %} pb-4.5 smd:pb-5{% else %} pb-8 smd:pb-4{% endif %}"
            {{ block.shopify_attributes }}
          >
            <div class="flex flex-col min-w-0 flex-1">
              <div class="relative z-2 flex items-center gap-3.5 smd:pr-[240px]">
                <div
                  class="aw-how-it-works__index relative shrink-0 size-15 -ml-2.5 rounded-full filter-[drop-shadow(0_4px_4px_rgba(0,0,0,0.25))] before:content-[''] before:absolute before:inset-1.25 before:rounded-full before:border-2 before:border-espresso bg-[#FDEDE0] flex items-center justify-center smd:-ml-2"
                  aria-hidden="true"
                >
                  <span class="font-gothic_condensed font-extrabold text-[25px] leading-none text-espresso">
                    {{ forloop.index }}
                  </span>
                </div>

                {% if block.settings.title != blank %}
                  <h3 class="font-gothic_condensed font-extrabold text-[25px] leading-none text-espresso pb-1">
                    {{ block.settings.title }}
                  </h3>
                {% endif %}
              </div>

              <div class="relative z-1 h-px w-[calc(100%+36px)] bg-[#CFBDB1]/60 -ml-4.5 -mt-1.5 smd:-ml-6 smd:w-[calc(100%+48px)]"></div>

              {% if block.settings.description != blank %}
                <div class="rte font-kurdis-semi-condensed font-semibold text-sm leading-[1.3] w-full text-espresso pt-3.5 [&_p]:mb-0 lg:px-1.5{% if action_type == 'join' or action_type == 'custom_button' %} max-w-[286px] smd:pt-3{% else %} smd:pt-4.75{% endif %}">
                  {{ block.settings.description | replace: '\n', '<br>' }}
                </div>
              {% endif %}
            </div>

            {% if show_action %}
              <div class="
                w-full mt-1 z-2 smd:absolute smd:right-6 smd:max-w-[232px] smd:-bottom-auto smd:left-auto smd:right-4.5 smd:mt-0 smd:shrink-0 smd:self-center smd:flex smd:items-center smd:justify-end
                {% if action_type == 'join' or action_type == 'custom_button' %} absolute left-4.5 -bottom-6.5 max-w-[calc(100%-36px)] smd:bottom-auto smd:left-auto smd:right-5 smd:top-9{% endif %}
                {% if action_type == 'link' %} smd:top-7 smd:text-right{% endif %}
              ">
                {% if action_type == 'join' %}
                  {% capture join_modal_attrs %}@click.prevent="$dispatch('modal-open', { modal: 'membership-signup' })"{% endcapture %}
                  {% render 'wb-button',
                    style: 'secondary',
                    label: join_label,
                    link: '#',
                    attributes: join_modal_attrs,
                    class: 'w-full!  min-w-0 md:min-w-[205px]! min-h-[43px] !text-xl'
                  %}
                {% elsif action_type == 'custom_button' %}
                  {% render 'wb-button',
                    style: custom_style,
                    label: custom_label,
                    link: custom_link,
                    class: 'w-full! min-w-0 md:min-w-[205px]! min-h-[43px] !text-xl'
                  %}
                {% elsif action_type == 'link' %}
                  <a
                    href="{{ link_url }}"
                    class="inline-block font-kurdis-semi-condensed font-semibold text-sm leading-[1.3] text-espresso underline decoration-espresso underline-offset-2 md:text-right md:whitespace-nowrap md:hover:text-dark-gold! md:hover:decoration-dark-gold"
                  >
                    {{ link_label }}
                  </a>
                {% endif %}
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .aw-how-it-works__subtitle {
    font-size: var(--subtitle-size-mobile) !important;
  }

  .aw-how-it-works__title {
    font-size: var(--font-size-mobile) !important;
  }

  @media screen and (min-width: 1024px) {
    .aw-how-it-works__subtitle {
      font-size: var(--subtitle-size) !important;
    }

    .aw-how-it-works__title {
      font-size: var(--font-size) !important;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "AW How It Works",
  "tag": "section",
  "class": "aw-how-it-works-section",
  "settings": [
    {
      "type": "header",
      "content": "Subtitle"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "REWARDS, MADE RIDICULOUSLY EASY"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle color",
      "default": "#AF7404"
    },
    {
      "type": "range",
      "id": "subtitle_font_size",
      "label": "Subtitle size",
      "min": 10,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "subtitle_font_size_mobile",
      "label": "Subtitle size mobile",
      "min": 10,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "header",
      "content": "Title"
    },
    {
      "type": "select",
      "id": "title_type",
      "label": "Title type",
      "options": [
        { "value": "text", "label": "Text" },
        { "value": "image", "label": "Image" }
      ],
      "default": "text"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "How It Works",
      "info": "Use \\n to add a line break.",
      "visible_if": "{{ section.settings.title_type == 'text' }}"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#431A03",
      "visible_if": "{{ section.settings.title_type == 'text' }}"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Title size",
      "min": 16,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 35,
      "visible_if": "{{ section.settings.title_type == 'text' }}"
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "label": "Title size mobile",
      "min": 16,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 35,
      "visible_if": "{{ section.settings.title_type == 'text' }}"
    },
    {
      "type": "text",
      "id": "title_alt",
      "label": "Title image alt",
      "visible_if": "{{ section.settings.title_type == 'image' }}"
    },
    {
      "type": "image_picker",
      "id": "title_image",
      "label": "Title image",
      "visible_if": "{{ section.settings.title_type == 'image' }}"
    },
    {
      "type": "image_picker",
      "id": "title_image_mobile",
      "label": "Title image mobile",
      "visible_if": "{{ section.settings.title_type == 'image' }}"
    },
    {
      "type": "header",
      "content": "Badge"
    },
    {
      "type": "image_picker",
      "id": "badge",
      "label": "Badge image",
      "info": "Shown at the top-right of the section (desktop)."
    },
    {
      "type": "range",
      "id": "badge_offset_x",
      "label": "Badge offset horizontal",
      "min": -50,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0,
      "info": "Negative moves left, positive moves right."
    },
    {
      "type": "range",
      "id": "badge_offset_y",
      "label": "Badge offset vertical",
      "min": -50,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0,
      "info": "Negative moves up, positive moves down."
    },
    {
      "type": "number",
      "id": "badge_rotate",
      "label": "Badge rotation",
      "default": 0,
      "info": "Rotation in degrees from 0 to 360."
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "select",
      "id": "background_type",
      "label": "Background type",
      "options": [
        { "value": "transparent", "label": "Transparent" },
        { "value": "color", "label": "Color" },
        { "value": "gradient", "label": "Gradient" },
        { "value": "image", "label": "Image" }
      ],
      "default": "gradient"
    },
    {
      "type": "color",
      "id": "background_solid",
      "label": "Background color",
      "default": "#F2E6DC",
      "visible_if": "{{ section.settings.background_type == 'color' }}"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "Background gradient",
      "default": "linear-gradient(180deg, #F2E6DC 0%, #BFD7E9 100%)",
      "visible_if": "{{ section.settings.background_type == 'gradient' }}"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image",
      "visible_if": "{{ section.settings.background_type == 'image' }}"
    },
    {
      "type": "header",
      "content": "Background mobile"
    },
    {
      "type": "select",
      "id": "background_type_mobile",
      "label": "Background type mobile",
      "options": [
        { "value": "same", "label": "Same as desktop" },
        { "value": "transparent", "label": "Transparent" },
        { "value": "color", "label": "Color" },
        { "value": "gradient", "label": "Gradient" },
        { "value": "image", "label": "Image" }
      ],
      "default": "same"
    },
    {
      "type": "color",
      "id": "background_solid_mobile",
      "label": "Background color mobile",
      "default": "#F2E6DC",
      "visible_if": "{{ section.settings.background_type_mobile == 'color' }}"
    },
    {
      "type": "color_background",
      "id": "background_gradient_mobile",
      "label": "Background gradient mobile",
      "visible_if": "{{ section.settings.background_type_mobile == 'gradient' }}"
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Background image mobile",
      "visible_if": "{{ section.settings.background_type_mobile == 'image' }}"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "Left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "Right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.mobile"
    },
    {
      "type": "range",
      "id": "padding-block-start-mobile",
      "label": "t:settings.top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-block-end-mobile",
      "label": "t:settings.bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-inline-start-mobile",
      "label": "Left mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end-mobile",
      "label": "Right mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Sign up"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>Join for free in seconds and get $5 off your first order. Just for signing up!</p>",
          "info": "Use \\n to add a line break."
        },
        {
          "type": "header",
          "content": "Action"
        },
        {
          "type": "select",
          "id": "action_type",
          "label": "Action type",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "join", "label": "JOIN FOR FREE" },
            { "value": "custom_button", "label": "Custom button" },
            { "value": "link", "label": "Link" }
          ],
          "default": "none"
        },
        {
          "type": "text",
          "id": "join_label",
          "label": "Join button text",
          "default": "JOIN FOR FREE",
          "info": "Shown only to guests (not logged in).",
          "visible_if": "{{ block.settings.action_type == 'join' }}"
        },
        {
          "type": "text",
          "id": "custom_button_label",
          "label": "Custom button text",
          "visible_if": "{{ block.settings.action_type == 'custom_button' }}"
        },
        {
          "type": "url",
          "id": "custom_button_link",
          "label": "Custom button URL",
          "visible_if": "{{ block.settings.action_type == 'custom_button' }}"
        },
        {
          "type": "select",
          "id": "custom_button_style",
          "label": "Custom button style",
          "options": [
            { "value": "primary", "label": "Primary" },
            { "value": "secondary", "label": "Secondary" }
          ],
          "default": "secondary",
          "visible_if": "{{ block.settings.action_type == 'custom_button' }}"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link text",
          "visible_if": "{{ block.settings.action_type == 'link' }}"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL",
          "visible_if": "{{ block.settings.action_type == 'link' }}"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "AW How It Works",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Sign up",
            "description": "<p>Join for free in seconds and get $5 off your first order. Just for signing up!</p>",
            "action_type": "join",
            "join_label": "JOIN FOR FREE"
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Sip & Earn",
            "description": "<p>Earn $5 for every $50 you spend. The more you sip, the more you earn! Plus, VIP and Elite members can access exclusive flavors and even bigger discounts.</p>",
            "action_type": "link",
            "link_label": "View all member tiers"
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Redeem, then repeat",
            "description": "<p>Cash in your credit at checkout for money off your cold brew. Then do it all over again.</p>",
            "action_type": "none"
          }
        }
      ]
    }
  ]
}
{% endschema %}
