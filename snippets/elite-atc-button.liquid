{%- doc -%}
  Renders a button that adds the Elite membership product to cart. Once the product is in the cart
  (checked on load + set after adding), the button swaps to the "in cart" label and blocks further
  clicks (Alpine `eliteAtc`).

  @param {string} label - Button label
  @param {string} [in_cart_label] - Label shown once the Elite product is in the cart
    (default: customer.dashboard.elite_in_cart)
  @param {string} [class] - Additional button classes
  @param {string} [wrapper_classes] - Additional classes for the wrapper
  @param {string} [style] - wb-button style, default secondary-gold
{%- enddoc -%}

{% liquid
  assign elite_product = settings.elite_product
  assign elite_variant = elite_product.selected_or_first_available_variant
  assign elite_selling_plan = 'null'
  if elite_variant.selling_plan_allocations.size > 0
    assign elite_selling_plan = elite_variant.selling_plan_allocations.first.selling_plan.id
  endif
  assign button_style = style | default: 'secondary-gold'
  assign in_cart_label = in_cart_label | default: ''
  if in_cart_label == blank
    assign in_cart_label = 'customer.dashboard.elite_in_cart' | t
  endif
%}

{% if elite_variant != blank and label != blank %}
  <div x-data="eliteAtc({ variantId: {{ elite_variant.id }}, sellingPlan: {{ elite_selling_plan }} })" class="{{ wrapper_classes }}">
    <a href="#"
       @click.prevent="addToCart()"
       :class="inCart && 'wb-elite-added'"
       :aria-disabled="inCart"
       class="btn {{ button_style }} {% if class %}{{ class }}{% endif %}">
      <span class="mt-0.5" x-text="inCart ? '{{ in_cart_label }}' : '{{ label }}'">{{ label }}</span>
      <svg preserveAspectRatio="none" class="btn-svg w-full h-full drop-shadow-[4px_4px_4px_rgba(0,0,0,0.25)]" width="280" height="47" viewBox="0 0 280 47" fill="none">
        <path d="M2.59169 4.88727C0.390365 7.61342 0.302126 10.8262 0.264973 13.9059C0.176734 21.2351 0.09314 28.5613 0.00490134 35.8904C-0.0183194 37.8822 -0.0136752 39.9555 1.33777 41.7417C4.59331 46.0364 8.70337 46.9734 20.8617 46.9734C102.413 46.9734 183.968 47.1336 265.524 46.6681C268.418 46.653 271.594 46.7497 273.967 45.6707C280.399 42.7481 279.698 37.4077 279.503 33.4454C279.141 26.0678 280 20.005 280 12.6245C280 7.4623 279.113 5.38898 276.484 3.34587C273.117 0.725503 266.105 0.83733 260.852 0.767816C226.318 0.305398 191.766 0.0666329 157.218 0.0122307C122.448 -0.0451938 87.6769 0.0998786 52.9063 0.441403C43.0979 0.538118 33.2941 0.649945 23.4903 0.779905C16.0876 0.87662 6.6971 -0.187244 2.59169 4.88727Z"/>
      </svg>
    </a>
  </div>
{% endif %}
