{%- doc -%}
  Renders one filter value as a pill link.

  @param {string} label - Pill text
  @param {string} url - Where the pill points
  @param {boolean} is_current - Whether this pill is the active selection
  @param {number} [count] - Matching product count, announced to screen readers
{%- enddoc -%}

<li>
  <a
    href="{{ url }}"
    class="
      filter-pills__pill inline-flex !justify-center text-center items-center gap-1.5 whitespace-nowrap rounded-[10px] min-w-[87px]
      border-[1.5px] border-espresso px-2 lg:px-4 py-2 font-kurdis-semi-condensed text-[15px]
      font-bold leading-tight no-underline transition-all duration-300
      {% if is_current %}
        bg-kraft text-foam shadow-button
      {% else %}
        bg-cream text-espresso hover:border-gold hover:bg-gold hover:!text-white
      {% endif %}
    "
    on:click="filter-pills-component/navigate"
    data-announce="{{ label | escape }}{% if count %}, {{ count }} {{ count | pluralize: 'product', 'products' }}{% endif %}"
    {% if is_current %}
      aria-current="true"
    {% endif %}
  >
    {{- label -}}
  </a>
</li>
